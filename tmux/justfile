set shell := ["bash", "-euo", "pipefail", "-c"]

import '../.build/just/lib.just'

dotdir := shell("yq '.dotdir' data.yml | envsubst")
tpm_dir := env("HOME") + "/.tmux/plugins/tpm"

install: dependencies config tpm
    @echo "tmux: Installation complete"
    @echo "  Run 'tmux' then press 'prefix + I' to install plugins"

dependencies:
    brew bundle install --file "{{justfile_directory()}}/brewfile"

config: mktree
    ln -sf "{{justfile_directory()}}/tmux.conf" "{{dotdir}}/tmux.conf"
    ln -sf "{{justfile_directory()}}/tmux.reset.conf" "{{dotdir}}/tmux.reset.conf"
    @echo "Config symlinked to {{dotdir}}"

mktree:
    mkdir -p "{{dotdir}}"

# Install TPM (Tmux Plugin Manager) if not present
tpm:
    #!/usr/bin/env bash
    if [[ ! -d "{{tpm_dir}}" ]]; then
        echo "Installing TPM (Tmux Plugin Manager)..."
        git clone https://github.com/tmux-plugins/tpm "{{tpm_dir}}"
        echo "TPM installed. Press 'prefix + I' in tmux to install plugins."
    else
        echo "TPM already installed at {{tpm_dir}}"
    fi

# Update TPM and all plugins
update-plugins:
    "{{tpm_dir}}/bin/update_plugins" all

# Clean TPM plugins
clean-plugins:
    "{{tpm_dir}}/bin/clean_plugins"
