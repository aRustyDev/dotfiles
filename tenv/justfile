set shell := ["bash", "-euo", "pipefail", "-c"]

import '../.build/just/lib.just'

# tenv root directory
tenv_root := env_var("HOME") / ".tenv"

# Install tenv
install: dependencies config
    @echo "tenv installed. Use 'tenv tf install' to install Terraform versions."

# Install dependencies
dependencies:
    brew bundle --file=brewfile --no-lock

# Configure shell integration
config:
    @echo "Add to your shell config:"
    @echo '  export TENV_ROOT="$HOME/.tenv"'
    @echo '  export TENV_AUTO_INSTALL=true'
    @echo '  export PATH="$TENV_ROOT/bin:$PATH"'

# Create tenv directories
mktree:
    mkdir -p "{{tenv_root}}"
    mkdir -p "{{tenv_root}}/Terraform"
    mkdir -p "{{tenv_root}}/OpenTofu"
    mkdir -p "{{tenv_root}}/Terragrunt"

# =============================================================================
# Terraform
# =============================================================================

# Install latest Terraform
tf-latest:
    tenv tf install latest

# Install specific Terraform version
tf-install version:
    tenv tf install {{version}}

# List installed Terraform versions
tf-list:
    tenv tf list

# List available Terraform versions
tf-list-remote:
    tenv tf list-remote

# Set default Terraform version
tf-use version:
    tenv tf use {{version}}

# Show current Terraform version
tf-version:
    tenv tf version

# =============================================================================
# OpenTofu
# =============================================================================

# Install latest OpenTofu
tofu-latest:
    tenv tofu install latest

# Install specific OpenTofu version
tofu-install version:
    tenv tofu install {{version}}

# List installed OpenTofu versions
tofu-list:
    tenv tofu list

# Set default OpenTofu version
tofu-use version:
    tenv tofu use {{version}}

# =============================================================================
# Terragrunt
# =============================================================================

# Install latest Terragrunt
tg-latest:
    tenv tg install latest

# Install specific Terragrunt version
tg-install version:
    tenv tg install {{version}}

# List installed Terragrunt versions
tg-list:
    tenv tg list

# Set default Terragrunt version
tg-use version:
    tenv tg use {{version}}

# =============================================================================
# Utility
# =============================================================================

# Install latest of all tools
install-all: tf-latest tofu-latest tg-latest
    @echo "Installed latest versions of Terraform, OpenTofu, and Terragrunt"

# Show all installed versions
list-all:
    @echo "=== Terraform ==="
    @tenv tf list 2>/dev/null || echo "  (none)"
    @echo ""
    @echo "=== OpenTofu ==="
    @tenv tofu list 2>/dev/null || echo "  (none)"
    @echo ""
    @echo "=== Terragrunt ==="
    @tenv tg list 2>/dev/null || echo "  (none)"

# Update all tools to latest
update-all:
    tenv tf install latest
    tenv tofu install latest
    tenv tg install latest
    @echo "Updated all tools to latest versions"

# Show tenv info
info:
    @echo "TENV_ROOT: {{tenv_root}}"
    @echo ""
    @echo "Current versions:"
    @echo "  Terraform:  $(tenv tf version 2>/dev/null || echo 'not installed')"
    @echo "  OpenTofu:   $(tenv tofu version 2>/dev/null || echo 'not installed')"
    @echo "  Terragrunt: $(tenv tg version 2>/dev/null || echo 'not installed')"

# Clean old versions (keep only latest)
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "This will remove all but the latest version of each tool."
    read -p "Continue? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        for tool in tf tofu tg; do
            latest=$(tenv $tool list 2>/dev/null | tail -1)
            if [[ -n "$latest" ]]; then
                tenv $tool list 2>/dev/null | grep -v "^$latest$" | while read v; do
                    echo "Removing $tool $v..."
                    tenv $tool uninstall "$v" 2>/dev/null || true
                done
            fi
        done
        echo "Cleanup complete"
    fi
