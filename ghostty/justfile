set shell := ["bash", "-euo", "pipefail", "-c"]

import '../.build/just/lib.just'

dotdir := shell("yq '.dotdir' data.yml | envsubst")

install: dependencies config
    @echo "ghostty: Installation complete"
    @echo "  Quick terminal: Ctrl+\` (global hotkey)"

dependencies:
    brew bundle install --file "{{justfile_directory()}}/brewfile"

config: mktree
    ln -sf "{{justfile_directory()}}/config" "{{dotdir}}/config"

mktree:
    mkdir -p "{{dotdir}}"
