set shell := ["bash", "-euo", "pipefail", "-c"]

import '../.build/just/lib.just'

# Zen Browser paths
zen_support := home_dir / "Library/Application Support/zen"
profiles_dir := zen_support / "Profiles"
macos_domain := "app.zen-browser.zen"

# Install Zen Browser
install: dependencies onepassword-integration
    @echo "Zen Browser installed. Configure extensions manually or restore from backup."

# Install dependencies
dependencies:
    brew bundle --file=brewfile --no-lock

# Enable 1Password browser integration
onepassword-integration:
    #!/usr/bin/env bash
    set -euo pipefail
    op_config="/etc/1password/custom_allowed_browsers"
    if [[ ! -f "$op_config" ]] || ! grep -q "zen" "$op_config" 2>/dev/null; then
        echo "Adding Zen to 1Password allowed browsers..."
        sudo mkdir -p /etc/1password
        echo "zen" | sudo tee -a "$op_config" > /dev/null
        echo "zen-bin" | sudo tee -a "$op_config" > /dev/null
        echo "Done. Restart 1Password and Zen Browser."
    else
        echo "Zen already in 1Password allowed browsers"
    fi

# List available profiles
profiles:
    @echo "Zen Browser profiles:"
    @ls -1 "{{profiles_dir}}" 2>/dev/null || echo "  (no profiles found)"

# Backup a profile
backup profile:
    #!/usr/bin/env bash
    set -euo pipefail
    profile_path="{{profiles_dir}}/{{profile}}"
    backup_path="{{justfile_directory()}}/backups/{{profile}}-$(date +%Y%m%d).tar.gz"

    if [[ ! -d "$profile_path" ]]; then
        echo "Profile not found: {{profile}}"
        echo "Available profiles:"
        ls -1 "{{profiles_dir}}"
        exit 1
    fi

    mkdir -p "{{justfile_directory()}}/backups"
    echo "Backing up profile {{profile}}..."
    tar -czf "$backup_path" -C "{{profiles_dir}}" "{{profile}}"
    echo "Created: $backup_path"

# Restore a profile from backup
restore backup_file profile:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ ! -f "{{backup_file}}" ]]; then
        echo "Backup not found: {{backup_file}}"
        exit 1
    fi

    echo "Restoring to profile {{profile}}..."
    mkdir -p "{{profiles_dir}}"
    tar -xzf "{{backup_file}}" -C "{{profiles_dir}}"
    echo "Restored. You may need to update profiles.ini"

# Open profile folder
open-profile profile:
    open "{{profiles_dir}}/{{profile}}"

# List installed extensions (reads extensions.json from profile)
extensions profile:
    #!/usr/bin/env bash
    set -euo pipefail
    ext_file="{{profiles_dir}}/{{profile}}/extensions.json"
    if [[ -f "$ext_file" ]]; then
        echo "Installed extensions in {{profile}}:"
        jq -r '.addons[] | select(.type == "extension") | "  - \(.defaultLocale.name // .id)"' "$ext_file" 2>/dev/null || cat "$ext_file"
    else
        echo "No extensions.json found for profile {{profile}}"
    fi

# Export extension list from profile
export-extensions profile:
    #!/usr/bin/env bash
    set -euo pipefail
    ext_file="{{profiles_dir}}/{{profile}}/extensions.json"
    if [[ -f "$ext_file" ]]; then
        echo "Exporting extension list..."
        jq -r '.addons[] | select(.type == "extension") | {id: .id, name: .defaultLocale.name}' "$ext_file" > "{{justfile_directory()}}/extensions-export.json"
        echo "Exported to extensions-export.json"
    else
        echo "No extensions.json found"
    fi

# Show Zen Browser info
info:
    @echo "Zen Browser Application Support: {{zen_support}}"
    @echo "Profiles directory: {{profiles_dir}}"
    @echo ""
    @echo "Available profiles:"
    @ls -1 "{{profiles_dir}}" 2>/dev/null || echo "  (none)"

# Open about:profiles in Zen
about-profiles:
    open "zen://about:profiles"

# Open about:config in Zen
about-config:
    open "zen://about:config"
