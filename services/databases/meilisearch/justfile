# =============================================================================
# Meilisearch Configuration & Management
# =============================================================================
# Three-stage setup:
#   Stage 1: Install & basic validation (insecure, local development)
#   Stage 2: Health checks & integration (API, MCP, monitoring)
#   Stage 3: Production hardening (SSL, API keys, persistence, logging)
# =============================================================================

set shell := ["bash", "-euo", "pipefail", "-c"]

# Directory Configuration
meilisearch_dir := justfile_directory()
data_local := data_local_directory()
xdg_state := env("XDG_STATE_HOME", env("HOME") / ".local/state")
xdg_config := env("XDG_CONFIG_HOME", env("HOME") / ".config")
xdg_data := env("XDG_DATA_HOME", env("HOME") / ".local/share")

# Meilisearch paths
ms_data := data_local / "meilisearch"
ms_config := xdg_config / "meilisearch"
ms_state := xdg_state / "meilisearch"
ms_db := ms_data / "data.ms"
ms_dumps := ms_data / "dumps"
ms_snapshots := ms_data / "snapshots"
ms_logs := ms_state / "logs"
ms_certs := ms_data / "certs"

# Default configuration
default_host := "127.0.0.1"
default_port := "7700"
default_env := "development"

# Runtime configuration (can be overridden)
host := env("MEILI_HOST", default_host)
port := env("MEILI_PORT", default_port)
meili_env := env("MEILI_ENV", default_env)
meili_url := "http://" + host + ":" + port

# Required tools
mustache := require("mustache")

# =============================================================================
# Stage 1: Installation & Basic Setup (Insecure)
# =============================================================================

# Show all available recipes
[group("info")]
default:
    @just --list --unsorted

# Install Meilisearch via Homebrew
[group("stage1")]
install: mktree
    brew list meilisearch >/dev/null 2>&1 || brew install meilisearch
    @echo "✓ Meilisearch installed"
    @meilisearch --version

# Create necessary directories
[group("stage1")]
mktree:
    mkdir -p "{{ ms_data }}"
    mkdir -p "{{ ms_config }}"
    mkdir -p "{{ ms_state }}"
    mkdir -p "{{ ms_db }}"
    mkdir -p "{{ ms_dumps }}"
    mkdir -p "{{ ms_snapshots }}"
    mkdir -p "{{ ms_logs }}"
    mkdir -p "{{ ms_certs }}"
    @echo "✓ Directory structure created"

# Generate development config (no master key, insecure)
[group("stage1")]
config-dev: mktree
    #!/usr/bin/env bash
    cat > "{{ ms_config }}/config.toml" << 'EOF'
    # Meilisearch Development Configuration (INSECURE)
    # Generated by: just config-dev

    db_path = "{{ ms_db }}"
    env = "development"
    http_addr = "{{ host }}:{{ port }}"

    # No master key in development (insecure, for local testing only)
    # master_key = ""

    no_analytics = true
    http_payload_size_limit = "100 MB"
    log_level = "INFO"

    # Optimized for M5 with 32GB RAM
    max_indexing_memory = "8 GiB"
    max_indexing_threads = 8

    dump_dir = "{{ ms_dumps }}"
    snapshot_dir = "{{ ms_snapshots }}"

    # Experimental features
    experimental_enable_metrics = true
    EOF
    # Expand variables in the config
    envsubst < "{{ ms_config }}/config.toml" > "{{ ms_config }}/config.toml.tmp"
    mv "{{ ms_config }}/config.toml.tmp" "{{ ms_config }}/config.toml"
    echo "✓ Development config written to {{ ms_config }}/config.toml"

# Start Meilisearch in development mode (foreground)
[group("stage1")]
start-dev: config-dev
    @echo "Starting Meilisearch in development mode..."
    @echo "URL: {{ meili_url }}"
    @echo "Press Ctrl+C to stop"
    meilisearch --config-file-path "{{ ms_config }}/config.toml"

# Start Meilisearch in background (development)
[group("stage1")]
start-dev-bg: config-dev
    #!/usr/bin/env bash
    if pgrep -x meilisearch > /dev/null; then
        echo "Meilisearch is already running"
        exit 0
    fi
    nohup meilisearch --config-file-path "{{ ms_config }}/config.toml" \
        > "{{ ms_logs }}/meilisearch.log" 2>&1 &
    echo $! > "{{ ms_state }}/meilisearch.pid"
    sleep 2
    if pgrep -x meilisearch > /dev/null; then
        echo "✓ Meilisearch started (PID: $(cat {{ ms_state }}/meilisearch.pid))"
        echo "  URL: {{ meili_url }}"
        echo "  Logs: {{ ms_logs }}/meilisearch.log"
    else
        echo "✗ Failed to start Meilisearch"
        cat "{{ ms_logs }}/meilisearch.log"
        exit 1
    fi

# Stop Meilisearch (development background process)
[group("stage1")]
stop-dev:
    #!/usr/bin/env bash
    if [ -f "{{ ms_state }}/meilisearch.pid" ]; then
        pid=$(cat "{{ ms_state }}/meilisearch.pid")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid"
            rm "{{ ms_state }}/meilisearch.pid"
            echo "✓ Meilisearch stopped (PID: $pid)"
        else
            rm "{{ ms_state }}/meilisearch.pid"
            echo "PID file stale, removed"
        fi
    elif pgrep -x meilisearch > /dev/null; then
        pkill -x meilisearch
        echo "✓ Meilisearch stopped"
    else
        echo "Meilisearch is not running"
    fi

# Validate configuration syntax
[group("stage1")]
validate-config:
    #!/usr/bin/env bash
    config="{{ ms_config }}/config.toml"
    if [ ! -f "$config" ]; then
        echo "✗ Config not found: $config"
        echo "  Run: just config-dev"
        exit 1
    fi
    # Basic TOML validation
    if command -v taplo &> /dev/null; then
        taplo check "$config" && echo "✓ Config syntax valid"
    else
        echo "⚠ taplo not installed, skipping syntax validation"
        echo "  Install with: cargo install taplo-cli"
    fi

# Show current configuration
[group("stage1")]
show-config:
    @cat "{{ ms_config }}/config.toml" 2>/dev/null || echo "No config found. Run: just config-dev"

# Clean all Meilisearch data (DESTRUCTIVE)
[group("stage1")]
[confirm("This will delete all Meilisearch data. Continue?")]
clean:
    rm -rf "{{ ms_data }}"
    rm -rf "{{ ms_config }}"
    rm -rf "{{ ms_state }}"
    @echo "✓ All Meilisearch data cleaned"

# Uninstall Meilisearch completely
[group("stage1")]
[confirm("This will uninstall Meilisearch and delete all data. Continue?")]
uninstall: stop-dev clean
    brew uninstall meilisearch 2>/dev/null || true
    @echo "✓ Meilisearch uninstalled"

# =============================================================================
# Stage 2: Health Checks & Integration
# =============================================================================

# Check if Meilisearch is healthy
[group("stage2")]
health:
    #!/usr/bin/env bash
    response=$(curl -s -w "\n%{http_code}" "{{ meili_url }}/health" 2>/dev/null)
    http_code=$(echo "$response" | tail -1)
    body=$(echo "$response" | head -n -1)

    if [ "$http_code" = "200" ]; then
        echo "✓ Meilisearch is healthy"
        echo "  Status: $(echo "$body" | jq -r '.status // "available"')"
    else
        echo "✗ Meilisearch is not reachable"
        echo "  URL: {{ meili_url }}"
        echo "  HTTP Code: $http_code"
        exit 1
    fi

# Get Meilisearch version and stats
[group("stage2")]
info:
    #!/usr/bin/env bash
    echo "=== Meilisearch Info ==="
    echo ""
    echo "Version:"
    curl -s "{{ meili_url }}/version" | jq '.' 2>/dev/null || echo "  Not reachable"
    echo ""
    echo "Stats:"
    curl -s "{{ meili_url }}/stats" | jq '.' 2>/dev/null || echo "  Not reachable"

# List all indexes
[group("stage2")]
list-indexes key="":
    #!/usr/bin/env bash
    auth_header=""
    if [ -n "{{ key }}" ]; then
        auth_header="-H 'Authorization: Bearer {{ key }}'"
    fi
    curl -s $auth_header "{{ meili_url }}/indexes" | jq '.'

# Create a test index
[group("stage2")]
test-index key="":
    #!/usr/bin/env bash
    auth_header=""
    if [ -n "{{ key }}" ]; then
        auth_header="-H 'Authorization: Bearer {{ key }}'"
    fi

    echo "Creating test index..."
    curl -s -X POST $auth_header \
        -H "Content-Type: application/json" \
        "{{ meili_url }}/indexes" \
        -d '{"uid": "test-index", "primaryKey": "id"}' | jq '.'

    echo ""
    echo "Adding test documents..."
    curl -s -X POST $auth_header \
        -H "Content-Type: application/json" \
        "{{ meili_url }}/indexes/test-index/documents" \
        -d '[
            {"id": 1, "title": "Hello World", "content": "First test document"},
            {"id": 2, "title": "Meilisearch", "content": "Fast search engine"},
            {"id": 3, "title": "Testing", "content": "This is a test"}
        ]' | jq '.'

    sleep 1
    echo ""
    echo "Test search..."
    curl -s -X POST $auth_header \
        -H "Content-Type: application/json" \
        "{{ meili_url }}/indexes/test-index/search" \
        -d '{"q": "test"}' | jq '.'

# Delete test index
[group("stage2")]
delete-test-index key="":
    #!/usr/bin/env bash
    auth_header=""
    if [ -n "{{ key }}" ]; then
        auth_header="-H 'Authorization: Bearer {{ key }}'"
    fi
    curl -s -X DELETE $auth_header "{{ meili_url }}/indexes/test-index" | jq '.'
    echo "✓ Test index deleted"

# Get Prometheus metrics (if enabled)
[group("stage2")]
metrics:
    curl -s "{{ meili_url }}/metrics" 2>/dev/null || echo "Metrics not available (enable experimental_enable_metrics)"

# Watch logs in real-time
[group("stage2")]
logs:
    tail -f "{{ ms_logs }}/meilisearch.log" 2>/dev/null || echo "No log file found"

# Get task status
[group("stage2")]
tasks key="":
    #!/usr/bin/env bash
    auth_header=""
    if [ -n "{{ key }}" ]; then
        auth_header="-H 'Authorization: Bearer {{ key }}'"
    fi
    curl -s $auth_header "{{ meili_url }}/tasks?limit=10" | jq '.'

# Create a dump
[group("stage2")]
dump key="":
    #!/usr/bin/env bash
    auth_header=""
    if [ -n "{{ key }}" ]; then
        auth_header="-H 'Authorization: Bearer {{ key }}'"
    fi
    curl -s -X POST $auth_header "{{ meili_url }}/dumps" | jq '.'
    echo "Dump initiated. Check tasks for completion."

# Quick connectivity test
[group("stage2")]
ping:
    #!/usr/bin/env bash
    if curl -s --connect-timeout 2 "{{ meili_url }}/health" > /dev/null 2>&1; then
        echo "✓ {{ meili_url }} reachable"
    else
        echo "✗ {{ meili_url }} not reachable"
        exit 1
    fi

# =============================================================================
# Stage 3: Production Hardening (SSL, API Keys, Persistence)
# =============================================================================

# Generate SSL certificates using mkcert
[group("stage3")]
mkcerts:
    #!/usr/bin/env bash
    cd "{{ ms_certs }}"

    # Install local CA if not already done
    mkcert -install

    # Generate cert for localhost and common names
    mkcert -cert-file cert.pem -key-file key.pem \
        "localhost" "{{ host }}" \
        "search.localhost" "meilisearch.localhost" \
        "127.0.0.1" "::1"

    echo "✓ TLS certificates created in {{ ms_certs }}/"
    ls -la "{{ ms_certs }}"

# Generate production config with SSL and API key from 1Password
[group("stage3")]
config-prod: mktree mkcerts
    #!/usr/bin/env bash
    cat > "{{ ms_config }}/config-prod.toml" << 'TOMLEOF'
    # Meilisearch Production Configuration
    # Generated by: just config-prod

    db_path = "{{ ms_db }}"
    env = "production"
    http_addr = "{{ host }}:{{ port }}"

    # Master key from 1Password (injected at runtime)
    master_key = "op://Developer/meilisearch/credential"

    no_analytics = true
    http_payload_size_limit = "100 MB"
    log_level = "INFO"

    # Optimized for M5 with 32GB RAM
    max_indexing_memory = "8 GiB"
    max_indexing_threads = 8

    dump_dir = "{{ ms_dumps }}"
    ignore_missing_dump = false
    ignore_dump_if_db_exists = false

    snapshot_dir = "{{ ms_snapshots }}"
    schedule_snapshot = 86400  # Daily snapshots
    ignore_missing_snapshot = false
    ignore_snapshot_if_db_exists = false

    # SSL Configuration
    ssl_cert_path = "{{ ms_certs }}/cert.pem"
    ssl_key_path = "{{ ms_certs }}/key.pem"
    ssl_require_auth = false
    ssl_resumption = true
    ssl_tickets = true

    # Experimental features
    experimental_enable_metrics = true
    TOMLEOF

    # Expand variables
    envsubst < "{{ ms_config }}/config-prod.toml" > "{{ ms_config }}/config-prod.toml.tmp"
    mv "{{ ms_config }}/config-prod.toml.tmp" "{{ ms_config }}/config-prod.toml"

    echo "✓ Production config written to {{ ms_config }}/config-prod.toml"
    echo "  Note: master_key will be injected from 1Password at runtime"

# Start Meilisearch in production mode (with op inject)
[group("stage3")]
start-prod:
    #!/usr/bin/env bash
    if pgrep -x meilisearch > /dev/null; then
        echo "Meilisearch is already running"
        exit 0
    fi

    # Inject secrets from 1Password and start
    op inject -i "{{ ms_config }}/config-prod.toml" -o "{{ ms_state }}/config-runtime.toml"

    nohup meilisearch --config-file-path "{{ ms_state }}/config-runtime.toml" \
        > "{{ ms_logs }}/meilisearch.log" 2>&1 &
    echo $! > "{{ ms_state }}/meilisearch.pid"

    sleep 2
    if pgrep -x meilisearch > /dev/null; then
        echo "✓ Meilisearch started in production mode"
        echo "  PID: $(cat {{ ms_state }}/meilisearch.pid)"
        echo "  URL: https://{{ host }}:{{ port }}"
        echo "  Logs: {{ ms_logs }}/meilisearch.log"
    else
        echo "✗ Failed to start Meilisearch"
        cat "{{ ms_logs }}/meilisearch.log"
        exit 1
    fi

# Stop production Meilisearch
[group("stage3")]
stop-prod: stop-dev
    # Remove runtime config with secrets
    rm -f "{{ ms_state }}/config-runtime.toml"
    @echo "✓ Runtime config cleaned"

# Generate launchd plist for persistence
[group("stage3")]
launchd-install:
    #!/usr/bin/env bash
    plist_path="$HOME/Library/LaunchAgents/com.meilisearch.meilisearch.plist"

    cat > "$plist_path" << PLISTEOF
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
        <key>Label</key>
        <string>com.meilisearch.meilisearch</string>

        <key>ProgramArguments</key>
        <array>
            <string>/bin/bash</string>
            <string>-c</string>
            <string>op inject -i {{ ms_config }}/config-prod.toml -o {{ ms_state }}/config-runtime.toml && exec meilisearch --config-file-path {{ ms_state }}/config-runtime.toml</string>
        </array>

        <key>RunAtLoad</key>
        <true/>

        <key>KeepAlive</key>
        <dict>
            <key>SuccessfulExit</key>
            <false/>
        </dict>

        <key>StandardOutPath</key>
        <string>{{ ms_logs }}/meilisearch.log</string>

        <key>StandardErrorPath</key>
        <string>{{ ms_logs }}/meilisearch-error.log</string>

        <key>WorkingDirectory</key>
        <string>{{ ms_data }}</string>

        <key>EnvironmentVariables</key>
        <dict>
            <key>PATH</key>
            <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        </dict>

        <key>ProcessType</key>
        <string>Background</string>

        <key>LowPriorityIO</key>
        <false/>

        <key>Nice</key>
        <integer>0</integer>
    </dict>
    </plist>
    PLISTEOF

    echo "✓ LaunchAgent plist created at $plist_path"
    echo ""
    echo "To enable:"
    echo "  launchctl load $plist_path"
    echo ""
    echo "To disable:"
    echo "  launchctl unload $plist_path"
    echo ""
    echo "To check status:"
    echo "  launchctl list | grep meilisearch"

# Load launchd service
[group("stage3")]
launchd-load:
    launchctl load "$HOME/Library/LaunchAgents/com.meilisearch.meilisearch.plist"
    @echo "✓ Meilisearch service loaded"
    @sleep 2
    @just health

# Unload launchd service
[group("stage3")]
launchd-unload:
    launchctl unload "$HOME/Library/LaunchAgents/com.meilisearch.meilisearch.plist" 2>/dev/null || true
    @echo "✓ Meilisearch service unloaded"

# Remove launchd service completely
[group("stage3")]
launchd-remove: launchd-unload
    rm -f "$HOME/Library/LaunchAgents/com.meilisearch.meilisearch.plist"
    @echo "✓ LaunchAgent plist removed"

# Check launchd service status
[group("stage3")]
launchd-status:
    #!/usr/bin/env bash
    if launchctl list | grep -q "com.meilisearch.meilisearch"; then
        echo "✓ Meilisearch service is loaded"
        launchctl list | grep meilisearch
    else
        echo "✗ Meilisearch service is not loaded"
    fi

# Generate API keys (requires master key)
[group("stage3")]
create-api-keys master_key:
    #!/usr/bin/env bash
    echo "Creating search-only API key..."
    curl -s -X POST \
        -H "Authorization: Bearer {{ master_key }}" \
        -H "Content-Type: application/json" \
        "{{ meili_url }}/keys" \
        -d '{
            "name": "Search API Key",
            "description": "Key for search operations only",
            "actions": ["search"],
            "indexes": ["*"],
            "expiresAt": null
        }' | jq '.'

    echo ""
    echo "Creating admin API key..."
    curl -s -X POST \
        -H "Authorization: Bearer {{ master_key }}" \
        -H "Content-Type: application/json" \
        "{{ meili_url }}/keys" \
        -d '{
            "name": "Admin API Key",
            "description": "Key for administrative operations",
            "actions": ["*"],
            "indexes": ["*"],
            "expiresAt": null
        }' | jq '.'

# List API keys (requires master key)
[group("stage3")]
list-api-keys master_key:
    curl -s -H "Authorization: Bearer {{ master_key }}" "{{ meili_url }}/keys" | jq '.'

# Setup log rotation
[group("stage3")]
setup-logrotate:
    #!/usr/bin/env bash
    logrotate_conf="/opt/homebrew/etc/logrotate.d/meilisearch"

    sudo mkdir -p /opt/homebrew/etc/logrotate.d

    sudo tee "$logrotate_conf" > /dev/null << LOGEOF
    {{ ms_logs }}/*.log {
        daily
        rotate 7
        compress
        delaycompress
        missingok
        notifempty
        copytruncate
    }
    LOGEOF

    echo "✓ Logrotate config created at $logrotate_conf"
    echo "  Logs will be rotated daily, keeping 7 days"

# Full production setup (all stage 3 components)
[group("stage3")]
setup-prod: config-prod launchd-install setup-logrotate
    @echo ""
    @echo "=== Production Setup Complete ==="
    @echo ""
    @echo "Next steps:"
    @echo "  1. Ensure 1Password CLI is configured: op signin"
    @echo "  2. Create Meilisearch item in 1Password vault 'Developer'"
    @echo "     with field 'credential' containing your master key"
    @echo "  3. Load the service: just launchd-load"
    @echo "  4. Verify health: just health"
    @echo ""

