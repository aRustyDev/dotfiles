# Show MCP server configuration for Claude
[group("mcp")]
mcp-config key="":
    #!/usr/bin/env bash
    echo "Add this to your Claude MCP config (claude_desktop_config.json or .mcp.json):"
    echo ""
    cat << EOF
    {
      "mcpServers": {
        "meilisearch": {
          "command": "npx",
          "args": ["-y", "meilisearch-mcp"],
          "env": {
            "MEILI_HOST": "{{ meili_url }}",
            "MEILI_API_KEY": "{{ key }}"
          }
        }
      }
    }
    EOF

# Install MCP server globally
[group("mcp")]
mcp-install:
    npm install -g meilisearch-mcp 2>/dev/null || npx -y meilisearch-mcp --help
    @echo "✓ Meilisearch MCP server available"

# =============================================================================
# Convenience Aliases
# =============================================================================

# Quick start (development mode, background)
start: start-dev-bg

# Quick stop
stop: stop-dev

# Quick restart
restart: stop start
    @just health

# Status check
status:
    #!/usr/bin/env bash
    echo "=== Meilisearch Status ==="
    echo ""

    # Check if process is running
    if pgrep -x meilisearch > /dev/null; then
        pid=$(pgrep -x meilisearch)
        echo "Process: Running (PID: $pid)"
    else
        echo "Process: Not running"
    fi

    # Check launchd
    if launchctl list 2>/dev/null | grep -q "com.meilisearch.meilisearch"; then
        echo "LaunchAgent: Loaded"
    else
        echo "LaunchAgent: Not loaded"
    fi

    # Check health endpoint
    echo ""
    just health 2>/dev/null || true

# =============================================================================
# Component Collection
# =============================================================================

# Collector paths
scripts_dir := meilisearch_dir / "indices/scripts"
collector_script := scripts_dir / "collect.py"
collector_output := meilisearch_dir / "indices/raw"

# Collect components from registries
# Examples:
#   just collect                           # Collect all from all registries
#   just collect mcp_server                # Collect only mcp_server kind
#   just collect skill skillsmp.com        # Collect skills from skillsmp.com
#   just collect all all true              # Dry run all registries
[group("collect")]
collect kinds="all" registry="all" dry_run="false":
    #!/usr/bin/env bash
    cd "{{ scripts_dir }}"
    args=("--kinds" "{{ kinds }}" "--output" "{{ collector_output }}")

    if [ "{{ registry }}" != "all" ]; then
        args+=("--registry" "{{ registry }}")
    fi

    if [ "{{ dry_run }}" = "true" ]; then
        args+=("--dry-run")
    fi

    uv run python "{{ collector_script }}" "${args[@]}"

# Search for components via SearXNG
# Usage: just search "mcp server filesystem"
[group("collect")]
search query:
    cd "{{ scripts_dir }}" && uv run python "{{ collector_script }}" --search "{{ query }}" --output "{{ collector_output }}"

# Show collection progress and statistics
[group("collect")]
show-progress:
    cd "{{ scripts_dir }}" && uv run python "{{ collector_script }}" --stats --output "{{ collector_output }}"

# List available registries
[group("collect")]
ls:
    cd "{{ scripts_dir }}" && uv run python "{{ collector_script }}" --list-registries

# Run collector tests
[group("collect")]
test *args:
    cd "{{ scripts_dir }}" && uv run pytest collectors/ {{ args }}

# Generate coverage comparison report (compare collected vs expected)
# Usage: just coverage-report
#        just coverage-report true   # Verbose with per-kind details
[group("collect")]
coverage-report verbose="false":
    #!/usr/bin/env bash
    cd "{{ scripts_dir }}"
    args=("--coverage-report" "--output" "{{ collector_output }}")

    if [ "{{ verbose }}" = "true" ]; then
        args+=("--verbose")
    fi

    uv run python "{{ collector_script }}" "${args[@]}"

# Save coverage report as JSON
[group("collect")]
coverage-report-json output_file="coverage-report.json":
    cd "{{ scripts_dir }}" && uv run python "{{ collector_script }}" --coverage-report-json "{{ collector_output }}/{{ output_file }}" --output "{{ collector_output }}"

# Detect new components since last collection
# Usage: just detect-new
#        just detect-new true   # Verbose with component details
[group("collect")]
detect-new verbose="false":
    #!/usr/bin/env bash
    cd "{{ scripts_dir }}"
    args=("--detect-new" "--output" "{{ collector_output }}")

    if [ "{{ verbose }}" = "true" ]; then
        args+=("--verbose")
    fi

    uv run python "{{ collector_script }}" "${args[@]}"

# Backup current collection for future comparison
# Run this before a new collection to enable detect-new
[group("collect")]
backup-collection:
    cd "{{ scripts_dir }}" && uv run python "{{ collector_script }}" --backup-collection --output "{{ collector_output }}"
