set shell := ["bash", "-euo", "pipefail", "-c"]

# Meilisearch search engine
mod meilisearch 'meilisearch/justfile'
# Dolt SQL database with Git versioning
mod dolt 'dolt/justfile'

install:
    #!/usr/bin/env bash
    for mod in meilisearch dolt; do
        echo "📦 db:$mod"
        "{{ just_executable() }}" -f "{{ justfile_directory() }}/$mod/justfile" install
    done
