set shell := ["bash", "-euo", "pipefail", "-c"]

import '../../../.build/just/lib.just'

# Dolt directories
dolt_home := env_var("HOME") / ".dolt"
databases_dir := env_var("HOME") / ".local/share/dolt/databases"

# Server settings (port 13306 avoids MySQL 3306 and legacy dolt 3307 conflicts)
default_port := "13306"
default_host := "127.0.0.1"

# Daemon integration
launch_agents := env_var("HOME") / "Library/LaunchAgents"
dolt_state := env("XDG_STATE_HOME", env("HOME") / ".local/state") / "daemon/dolt"
brew_prefix := `brew --prefix`

# Install dolt with launchd service
install: dependencies config mktree launchd
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Loading dolt service..."
    "{{ just_executable() }}" -f "{{ justfile_directory() }}/../../../daemon/justfile" load dolt
    sleep 2
    # Verify health
    if mysql -h "{{ default_host }}" -P "{{ default_port }}" -u root -e "SELECT 1" &>/dev/null; then
        echo "✓ Dolt server running on {{ default_host }}:{{ default_port }}"
    else
        echo "⚠ Dolt server loaded but not yet responding (check logs with: just daemon logs dolt)"
    fi
    echo "✓ Dolt installed."

# Install dependencies via Homebrew
dependencies:
    brew bundle --file=brewfile --no-lock

# Configure dolt global settings
config: mktree
    #!/usr/bin/env bash
    # Set global config if not already set
    if ! dolt config --global --get user.name &>/dev/null; then
        echo "Configure dolt user (run manually):"
        echo "  dolt config --global --add user.email 'you@example.com'"
        echo "  dolt config --global --add user.name 'Your Name'"
    else
        echo "Dolt global config already set"
    fi

# Create directories
mktree:
    mkdir -p "{{dolt_home}}"
    mkdir -p "{{databases_dir}}"

# Generate and install launchd plist
launchd: mktree
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "{{ dolt_state }}"
    mkdir -p "{{ launch_agents }}"
    export HOMEBREW_PREFIX="{{ brew_prefix }}"
    export DOLT_HOST="{{ default_host }}"
    export DOLT_PORT="{{ default_port }}"
    export DOLT_DATA_DIR="{{ databases_dir }}"
    export DOLT_LOG_DIR="{{ dolt_state }}"
    envsubst < "{{ justfile_directory() }}/dolt.plist.template" \
        > "{{ launch_agents }}/dev.arusty.dolt.plist"
    echo "✓ Plist installed to {{ launch_agents }}/dev.arusty.dolt.plist"

# =============================================================================
# Database Management
# =============================================================================

# Initialize a new dolt database
init name:
    #!/usr/bin/env bash
    db_path="{{databases_dir}}/{{name}}"
    mkdir -p "$db_path"
    cd "$db_path" && dolt init
    echo "Database created at: $db_path"

# List databases
list:
    @echo "Dolt databases:"
    @ls -1 "{{databases_dir}}" 2>/dev/null || echo "  (none)"

# Open SQL shell for a database
sql name:
    cd "{{databases_dir}}/{{name}}" && dolt sql

# Show database status
status name:
    cd "{{databases_dir}}/{{name}}" && dolt status

# Show database log
log name:
    cd "{{databases_dir}}/{{name}}" && dolt log

# Show database diff
diff name:
    cd "{{databases_dir}}/{{name}}" && dolt diff

# Commit changes
commit name message:
    cd "{{databases_dir}}/{{name}}" && dolt add . && dolt commit -m "{{message}}"

# =============================================================================
# Server Mode
# =============================================================================

# Start dolt SQL server for a database
serve name port=default_port:
    @echo "Starting Dolt SQL server for {{name}} on port {{port}}..."
    cd "{{databases_dir}}/{{name}}" && dolt sql-server -P {{port}}

# Start dolt server (via daemon)
start:
    "{{ just_executable() }}" -f "{{ justfile_directory() }}/../../../daemon/justfile" load dolt

# Stop dolt server (via daemon)
stop:
    "{{ just_executable() }}" -f "{{ justfile_directory() }}/../../../daemon/justfile" unload dolt

# =============================================================================
# DoltgreSQL (PostgreSQL-compatible)
# =============================================================================

# Start doltgres server for a database
serve-pg name port="5432":
    @echo "Starting DoltgreSQL server for {{name}} on port {{port}}..."
    cd "{{databases_dir}}/{{name}}" && doltgres -P {{port}}

# =============================================================================
# Remote & Clone
# =============================================================================

# Clone a database from DoltHub
clone remote name="":
    #!/usr/bin/env bash
    if [[ -z "{{name}}" ]]; then
        # Extract name from remote URL
        name=$(basename "{{remote}}")
    else
        name="{{name}}"
    fi
    cd "{{databases_dir}}" && dolt clone "{{remote}}" "$name"
    echo "Cloned to: {{databases_dir}}/$name"

# Push database to remote
push name:
    cd "{{databases_dir}}/{{name}}" && dolt push

# Pull updates from remote
pull name:
    cd "{{databases_dir}}/{{name}}" && dolt pull

# =============================================================================
# Info
# =============================================================================

# Show dolt info
info:
    @echo "Dolt home: {{dolt_home}}"
    @echo "Databases: {{databases_dir}}"
    @echo ""
    @dolt version
    @echo ""
    @echo "Global config:"
    @dolt config --global --list 2>/dev/null || echo "  (not configured)"

# Show running servers
servers:
    @echo "Running Dolt servers:"
    @ls "{{dolt_home}}"/*.pid 2>/dev/null | while read f; do \
        name=$(basename "$f" .pid); \
        pid=$(cat "$f"); \
        if kill -0 "$pid" 2>/dev/null; then \
            echo "  $name (PID: $pid)"; \
        fi; \
    done || echo "  (none)"
