set shell := ["bash", "-euo", "pipefail", "-c"]

import '../../../.build/just/lib.just'

dotdir := shell("yq '.dotdir' data.yml | envsubst")

# Install zoxide with configuration
install: dependencies config
    @echo "zoxide installed. Source zoxide.zsh in your shell config."

# Install dependencies
dependencies:
    brew bundle --file=brewfile --no-lock

# Symlink configuration
config: mktree
    ln -sf "{{justfile_directory()}}/zoxide.zsh" "{{dotdir}}/zoxide.zsh"

# Create config directory
mktree:
    mkdir -p "{{dotdir}}"

# Show zoxide info
info:
    @echo "Config directory: {{dotdir}}"
    @echo ""
    @zoxide --version
    @echo ""
    @echo "Shell integration:"
    @echo "  Add to .zshrc: source {{dotdir}}/zoxide.zsh"
    @echo ""
    @echo "Database location:"
    @echo "  ~/.local/share/zoxide/db.zo"
