set shell := ["bash", "-euo", "pipefail", "-c"]

# ADR (Architecture Decision Records) tool
mod adrs 'adrs/justfile'
# Beads workspace tool
mod beads 'beads/justfile'
# Gastown project management
mod gastown 'gastown/justfile'

install:
    #!/usr/bin/env bash
    for mod in adrs beads gastown; do
        echo "📦 agent:$mod"
        "{{ just_executable() }}" -f "{{ justfile_directory() }}/$mod/justfile" install
    done
