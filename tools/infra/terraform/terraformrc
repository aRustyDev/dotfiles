# Terraform CLI Configuration
# https://developer.hashicorp.com/terraform/cli/config/config-file

# Plugin cache to avoid re-downloading providers
plugin_cache_dir = "$HOME/.terraform.d/plugin-cache"

# Disable checkpoint (update/security bulletin checks)
disable_checkpoint = true

# Provider installation settings
provider_installation {
  filesystem_mirror {
    path    = "$HOME/.terraform.d/plugins"
    include = ["registry.terraform.io/*/*"]
  }
  direct {
    exclude = []
  }
}

# Credentials for Terraform Cloud/Enterprise (use env vars or credentials block)
# credentials "app.terraform.io" {
