set shell := ["bash", "-euo", "pipefail", "-c"]

import '../../../.build/just/lib.just'

dotdir := shell("yq '.dotdir' data.yml | envsubst")

# Install helm with plugins and repositories
install: dependencies plugins repos
    @echo "Helm configured with plugins and repositories"

# Install dependencies via Homebrew
dependencies:
    brew bundle --file=brewfile --no-lock

# Create config directories
mktree:
    mkdir -p "{{dotdir}}"

# =============================================================================
# Plugins
# =============================================================================

# Install recommended helm plugins
plugins:
    #!/usr/bin/env bash
    set -euo pipefail

    plugins=(
        "https://github.com/databus23/helm-diff"      # Diff before upgrade
        "https://github.com/jkroepke/helm-secrets"    # Secret management
        "https://github.com/aslafy-z/helm-git"        # Git repo as chart source
    )

    echo "Installing helm plugins..."
    for plugin in "${plugins[@]}"; do
        name=$(basename "$plugin")
        if ! helm plugin list | grep -q "^${name}"; then
            echo "Installing $name..."
            helm plugin install "$plugin" || echo "Failed to install $name"
        else
            echo "$name already installed"
        fi
    done

# Update all plugins
plugins-update:
    helm plugin update --all

# List installed plugins
plugins-list:
    helm plugin list

# =============================================================================
# Repositories
# =============================================================================

# Add common helm repositories
repos:
    #!/usr/bin/env bash
    set -euo pipefail

    declare -A repos=(
        ["bitnami"]="https://charts.bitnami.com/bitnami"
        ["jetstack"]="https://charts.jetstack.io"
        ["prometheus-community"]="https://prometheus-community.github.io/helm-charts"
        ["grafana"]="https://grafana.github.io/helm-charts"
        ["ingress-nginx"]="https://kubernetes.github.io/ingress-nginx"
        ["cert-manager"]="https://charts.jetstack.io"
        ["hashicorp"]="https://helm.releases.hashicorp.com"
        ["external-secrets"]="https://charts.external-secrets.io"
        ["argo"]="https://argoproj.github.io/argo-helm"
    )

    echo "Adding helm repositories..."
    for name in "${!repos[@]}"; do
        url="${repos[$name]}"
        if ! helm repo list 2>/dev/null | grep -q "^${name}"; then
            echo "Adding $name..."
            helm repo add "$name" "$url" || echo "Failed to add $name"
        else
            echo "$name already added"
        fi
    done

    echo "Updating repositories..."
    helm repo update

# Update all repositories
repos-update:
    helm repo update

# List configured repositories
repos-list:
    helm repo list

# =============================================================================
# Utility
# =============================================================================

# Search for a chart across all repos
search chart:
    helm search repo "{{chart}}"

# Show helm environment
env:
    helm env

# Show helm info
info:
    @echo "Helm config: {{dotdir}}"
    @echo ""
    @echo "Helm version:"
    @helm version --short
    @echo ""
    @echo "Installed plugins:"
    @helm plugin list 2>/dev/null || echo "  (none)"
    @echo ""
    @echo "Configured repositories:"
    @helm repo list 2>/dev/null || echo "  (none)"
