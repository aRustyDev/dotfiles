set shell := ["bash", "-euo", "pipefail", "-c"]

import '../.build/just/lib.just'

# Get dotdir from data.yml
dotdir := `yq -r '.dotdir | envsubst' data.yml`

# Install kitty configuration
install: dependencies config

# Install dependencies via Homebrew
dependencies:
    brew bundle --file=brewfile --no-lock

# Symlink config files
config: mktree
    ln -sf "{{justfile_directory()}}/kitty.conf" "{{dotdir}}/kitty.conf"

# Create target directories
mktree:
    mkdir -p "{{dotdir}}"
    mkdir -p "{{dotdir}}/themes"

# Reload kitty configuration
reload:
    @if pgrep -q kitty; then \
        kill -SIGUSR1 $(pgrep kitty); \
        echo "Kitty config reloaded"; \
    else \
        echo "Kitty is not running"; \
    fi

# Show kitty info
info:
    @echo "Config directory: {{dotdir}}"
    @echo "Config file: {{dotdir}}/kitty.conf"
    @echo ""
    @kitty --version 2>/dev/null || echo "Kitty not installed"

# Open kitty config in editor
edit:
    $EDITOR "{{justfile_directory()}}/kitty.conf"

# List available themes
themes:
    @echo "Download themes from: https://github.com/catppuccin/kitty"
    @echo "Place in: {{dotdir}}/themes/"
