set shell := ["bash", "-euo", "pipefail", "-c"]

import '../.build/just/lib.just'

# Get dotdir from data.yml
dotdir := `yq -r '.dotdir | envsubst' data.yml`

# Install zellij configuration
install: dependencies config

# Install dependencies via Homebrew
dependencies:
    brew bundle --file=brewfile --no-lock

# Symlink config files
config: mktree
    ln -sf "{{justfile_directory()}}/config.kdl" "{{dotdir}}/config.kdl"

# Create target directories
mktree:
    mkdir -p "{{dotdir}}"
    mkdir -p "{{dotdir}}/layouts"
    mkdir -p "{{dotdir}}/themes"

# Show zellij info
info:
    @echo "Config directory: {{dotdir}}"
    @echo "Current version: $(zellij --version 2>/dev/null || echo 'not installed')"

# List active sessions
sessions:
    zellij list-sessions

# Attach to session (or create default)
attach session="default":
    zellij attach -c {{session}}

# Kill a session
kill session:
    zellij kill-session {{session}}

# Kill all sessions
kill-all:
    zellij kill-all-sessions
